<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:AnisimovApp.ViewModels"
    x:Class="AnisimovApp.Views.LoginPage">

    <ContentPage.BindingContext>
        <viewModels:LoginViewModel/>
    </ContentPage.BindingContext>

    <VerticalStackLayout
        Padding="30"
        Spacing="15"
        VerticalOptions="Center">

        <Label
            FontSize="28"
            HorizontalOptions="Center"
            Text="Авторизация" />

        <Entry
            Placeholder="Логин"
            Text="{Binding Login}" />

        <Entry
            Placeholder="Пароль"
            IsPassword="True"
            Text="{Binding Password}" />

        <Button
            Text="Войти"
            Command="{Binding LoginUserCommand}" />

    </VerticalStackLayout>

</ContentPage>